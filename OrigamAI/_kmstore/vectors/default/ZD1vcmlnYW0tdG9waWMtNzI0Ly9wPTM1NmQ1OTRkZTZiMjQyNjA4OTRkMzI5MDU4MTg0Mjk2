{"id":"d=origam-topic-724//p=356d594de6b24260894d329058184296","tags":{"__document_id":["origam-topic-724"],"__file_type":["text/plain"],"__file_id":["c906c6ae9787497eb574e2261743387b"],"__file_part":["8a2e3d54629d4ba79dc8db984f0a34c9"],"__part_n":["0"],"__sect_n":["0"],"source":["origam-community"],"category":["docs"],"categoryId":["8"],"topicId":["724"],"url":["https://community.origam.com/t/dynamically-loaded-libraries-in-server-scheduler/724"],"title":["Dynamically Loaded Libraries in Server/Scheduler"]},"payload":{"url":"","schema":"20231218A","file":"content.txt","text":"# Dynamically Loaded Libraries in Server/Scheduler\n\nCategory: docs\nURL: https://community.origam.com/t/dynamically-loaded-libraries-in-server-scheduler/724\n\n@washi (2020-06-20 10:23:47Z):\n \n The following text also applies to OrigamScheduler. \n \n Dynamically loaded libraries have to be placed in the root folder of the application. If the dynamically loaded library has its own dependencies, that are not included in the  Server , they have to be added to configuration file  Origam.Server.deps.json . On the other hand the loaded library doesn\u2019t have to be included there. \n For example let\u2019s have a project that contains a custom library  CustomServiceLibrary.dll , that is used as a workflow service and serves as a wrapper for  WrappedLibrary.dll . As described before to be able to use  CustomServiceLibrary.dll  we need to add  WrappedLibrary.dll  to configuration file  Origam.ServerCore.deps.json . \n First we need to add  WrappedLibrary.dll  to  libraries  section: \n  \u0022WrappedLibrary/1.0.0.0\u0022: {\n    \u0022type\u0022: \u0022reference\u0022,\n    \u0022serviceable\u0022: false,\n    \u0022sha512\u0022: \u0022\u0022\n}\n  \n And then we need to add an entry to  targets -\u003E .NETCoreApp,Version=v8.0 : \n  \u0022WrappedLibrary/1.0.0.0\u0022: {\n    \u0022runtime\u0022: {\n        \u0022WrappedLibrary.dll\u0022: {\n            \u0022assemblyVersion\u0022: \u00221.0.0.0\u0022,\n            \u0022fileVersion\u0022: \u00221.0.0.0\u0022\n        }\n    }\n}","vector_provider":"AI.Ollama.OllamaTextEmbeddingGenerator","vector_generator":"__","last_update":"2026-04-29T00:23:38"},"vector":[-0.06500362,-0.0010671549,-0.055521365,-0.00076522277,-0.004138412,-0.033529818,0.030018969,-0.034419693,-0.01289263,-0.0023702073,0.04053719,-0.0036530267,-0.037466493,-0.018878542,-0.0061901463,0.00471718,-0.0272601,0.003836551,-0.013789226,-0.010068824,0.041269805,-0.031599127,0.0046162587,0.053645536,-0.0023440442,0.026755335,-0.003939938,-0.01913229,0.0035410197,0.02267723,0.01320907,-0.038778603,0.0001687033,-0.023721242,-0.030025247,0.007719275,0.013959637,0.009968698,-0.045224816,0.04615016,-0.018652359,0.013954445,-0.031661395,0.03309596,0.013283779,-0.019732298,-0.004573225,-0.0010525016,0.009153583,-0.049767014,-0.04136285,-0.035145823,0.049446736,-0.052769266,0.01268954,0.04584004,-0.049470104,-0.049722087,-0.051095758,0.007961001,0.0073971725,0.0089085,-0.0037005828,-0.0012477044,0.00929494,0.012533318,-0.021941556,0.0026670396,-0.02847031,-0.014261021,0.0131289,0.017294236,-0.014228204,-0.009599653,-0.07980331,0.025126947,0.013023863,-0.034249604,-0.0019003819,0.026664432,-0.00025049396,-0.018279057,0.046571687,-0.015072782,-0.014135405,0.012825349,-0.022913741,0.06782406,0.014405784,0.012946354,0.0024307023,-0.010441486,0.04938509,-0.025798833,-0.05879641,0.012918469,0.027588546,0.027713586,0.06715311,0.0022238907,-0.0259497,-0.043304816,-0.061929498,0.023205813,0.026242556,-0.020410556,-0.014213263,-0.029020658,-0.046652872,-0.026420165,0.022188628,0.00194815,0.04058305,-0.0038336795,-0.015761198,-0.041922115,-0.030342815,-0.025750743,-0.002241114,-0.01936457,0.007669011,0.047321707,0.061558455,-0.020803686,-0.0023286068,0.0063990904,0.030364743,-0.0052266847,0.02444415,-0.0049811956,0.03154604,0.039870992,-0.02189305,-0.005268818,-0.05450191,0.009919948,0.02516801,0.013630246,-0.026993448,-0.0064974385,0.03709884,-0.012437959,0.018546