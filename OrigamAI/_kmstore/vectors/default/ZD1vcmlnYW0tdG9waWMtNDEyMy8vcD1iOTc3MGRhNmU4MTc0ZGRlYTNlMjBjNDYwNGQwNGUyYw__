 sources and services, highlighting integration through REST and SOAP APIs, and notes the model\u0027s association with both local and remote Git repositories.","vector_provider":"AI.Ollama.OllamaTextEmbeddingGenerator","vector_generator":"__","last_update":"2026-05-02T00:03:40"},"vector":[-0.00039562478,-0.012613506,-0.071058564,-0.008340733,-0.04062796,-0.05203903,-0.030877193,-0.004887066,-0.010176181,0.018882118,0.0030225746,0.010221782,-0.011417107,0.003610598,-0.007279558,0.02090364,0.03584289,0.040761318,0.014639829,0.01571374,-0.008211574,-0.012829614,0.05886104,-0.033008188,0.0012816082,0.021283317,-0.0010023327,-0.022126716,-0.0060978313,0.03670207,0.013245939,-0.04183757,0.012857962,0.017353568,-0.016046006,-0.0016588271,0.041355968,-0.00040607248,-0.051362503,0.052219704,-0.030541481,-0.018519832,-0.022771431,0.004511872,0.009255215,-0.0718111,-0.010988778,-0.0067542517,-0.025312455,-0.012397081,-0.045270413,-0.028560815,-0.016208226,-0.029883577,0.023452135,0.054545563,-0.06390152,-0.034821134,-0.07001404,0.057375558,-0.03449835,0.02795031,0.0103139905,-0.031049088,-0.008836085,0.026288334,0.008520515,0.009667827,-0.027025687,-0.029938066,-0.016782211,-0.0004636894,-0.029481795,-0.041126363,-0.05938139,0.017525377,0.011648152,-0.010214011,-0.049046326,0.016678946,-0.005972771,-0.03212721,0.029441757,-0.024324264,-0.056624535,0.03259499,-0.055395517,0.08246009,0.020812728,0.021621635,-0.02981887,-0.060403477,0.043380354,-0.020124959,-0.03328316,0.014468492,0.03279187,-0.004421357,0.026302455,0.04499894,-0.015154637,-0.06448914,-0.054544296,-0.025394192,-0.019470476,-0.009741039,0.019577308,-0.020918764,-0.03922714,-0.022139484,0.023295239,0.0026912396,0.04999365,-0.005520945,0.013262674,-0.027845604,-0.015170229,-0.027742354,-0.03459368,0.008817367,-0.03580793,0.0045786723,0.03073119,0.0039827577,-0.007743385,-0.010318971,0.00030239136,0.047956374,0.006968578,-0.011709623,0.020354763,0.00313768,-0.0075563206,-0.0013290427,-0.015110171,-0.0021004898,0.040