t reference that entity. \n For example, here\u2019s the default Lookup setup for the  Task  /  Priority_Id  field: \n          Field DefaultLookup setting  583\u00D7545 79.3 KB         \n The full benefit of Lookups becomes apparent when designing drop-down menus in your app\u2019s user interface. \n\n---\n\n@vikter (2025-02-05 14:33:48Z):\n This article replaces an older  text .","vector_provider":"AI.Ollama.OllamaTextEmbeddingGenerator","vector_generator":"__","last_update":"2026-04-29T00:22:57"},"vector":[-0.02064686,-0.019872565,-0.028524226,0.004715196,-0.027798668,-0.0421267,0.04472852,-0.011782162,-0.011159203,-0.038233917,-0.008795875,0.009042584,0.00085606676,0.031528592,0.026067303,0.004710213,-0.02538895,0.012018231,0.024085036,0.01767503,-0.021143261,-0.005202235,0.016899006,-0.019340128,-0.023440337,0.00667024,0.005477055,-0.0072667315,-0.01878348,-0.008616227,0.039182313,-0.064512365,-0.015942669,-0.01602374,-0.022404175,-0.0019041812,0.03738954,0.03303149,-0.022230396,0.030843306,-0.0099682,0.012270693,0.019499414,0.008307366,0.0024134081,-0.0111274645,0.0009711336,-0.0053939302,-0.028789809,-0.035867468,-0.048107672,0.01337054,-0.026460689,-0.0133259455,0.012958132,0.036202576,-0.06308662,-0.001810035,-0.055740867,-0.023243649,-0.0003314357,0.010157445,-0.021421421,0.015161451,-0.014168659,0.051684108,-0.019193323,0.006465244,-0.024782969,-0.054511715,0.0072352067,0.06143936,-0.02296518,0.003920017,-0.02654995,0.0080222655,0.018328777,0.02287457,-0.011175,-0.0003949887,-0.023603082,-0.012800277,0.012531474,-0.016184585,-0.0033007395,0.0009785608,0.014032602,0.100321464,0.015479063,0.02221213,0.00403169,-0.003904326,0.059414204,-0.008029198,0.019191364,-0.010783633,0.008961121,0.012965785,0.0048580766,-0.00738142,-0.01345573,0.01784795,-0.019136162,0.006269823,0.015671367,-0.04401322,-0.058674064,-0.023681168,0.024418829,-0.039312992,0.01213042,0.0069024367,0.040347334,0.025186328,0.013570182,-0.011161295,0.032288793,-0.020305766,0.0031583575,0.00390